{
  "name": "@ichintansoni/skills-master",
  "version": "0.1.0",
  "description": "Install tool-agnostic Apple & Android development skills into any AI coding tool (Claude Code, Cursor, Copilot, AGENTS.md).",
  "keywords": [
    "skills",
    "apple",
    "swift",
    "swiftui",
    "android",
    "kotlin",
    "jetpack-compose",
    "material3",
    "claude",
    "cursor",
    "copilot",
    "agents.md",
    "ai",
    "agent"
  ],
  "license": "MIT",
  "author": "Chintan Soni",
  "homepage": "https://github.com/iChintanSoni/skills-master#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iChintanSoni/skills-master.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/iChintanSoni/skills-master/issues"
  },
  "type": "module",
  "bin": {
    "skills-master": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "giget": "^3.2.0",
    "gray-matter": "^4.0.3",
    "semver": "^7.6.3",
    "yaml": "^2.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/semver": "^7.5.8",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
